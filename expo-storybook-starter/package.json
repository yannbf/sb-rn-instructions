{
  "name": "expo-storybook-starter",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "storybook:web": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:web:serve": "npx http-server ./storybook-static",
    "storybook-generate": "sb-rn-get-stories",
    "storybook": "cross-env EXPO_PUBLIC_STORYBOOK_ENABLED='true' expo start",
    "storybook:ios": "cross-env EXPO_PUBLIC_STORYBOOK_ENABLED='true' expo start --ios",
    "storybook:android": "cross-env EXPO_PUBLIC_STORYBOOK_ENABLED='true' expo start --android",
    "build:storybook:android": "eas build --profile storybook-android --platform android --local --output storybook-static/storybook.apk",
    "build:storybook:ios": "eas build --profile storybook-ios --platform ios --local --output storybook-static/storybook.tar.gz",
    "build:storybook:manifest": "npx chromatic generate-manifest -o storybook-static",
    "chromatic:setup": "yarn build:storybook:android && yarn build:storybook:manifest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/slider": "5.1.2",
    "expo": "^55",
    "expo-constants": "~55.0.9",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@chromatic-com/storybook": "^5.0.2",
    "@expo/metro-runtime": "~55.0.6",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/addon-ondevice-actions": "10.3.0",
    "@storybook/addon-ondevice-backgrounds": "10.3.0",
    "@storybook/addon-ondevice-controls": "10.3.0",
    "@storybook/addon-ondevice-notes": "10.3.0",
    "@storybook/react": "^10.3.1",
    "@storybook/react-native": "10.3.0",
    "@storybook/react-native-web-vite": "^10.3.1",
    "@types/react": "~19.2.10",
    "babel-plugin-react-docgen-typescript": "^1.5.1",
    "babel-plugin-react-native-web": "^0.19.10",
    "baseline-browser-mapping": "^2.10.9",
    "cross-env": "^10.1.0",
    "eslint": "^9.33.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-plugin-storybook": "^10.3.1",
    "jiti": "^2.5.1",
    "storybook": "^10.3.1",
    "typescript": "~5.9.2",
    "vite": "^8.0.1"
  },
  "resolutions": {
    "react-docgen-typescript": "2.2.2",
    "vite-plugin-rnw": "^0.0.11"
  },
  "overrides": {
    "react-docgen-typescript": "2.2.2",
    "vite-plugin-rnw": "^0.0.11"
  },
  "pnpm": {
    "overrides": {
      "react-docgen-typescript": "2.2.2",
      "vite-plugin-rnw": "^0.0.11"
    }
  },
  "packageManager": "yarn@4.7.0"
}
